generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String               @id @default(uuid())
  email                String               @unique
  name                 String?
  password             String
  googleId             String?              @unique
  role                 UserRole             @default(USER)
  credits              Int                  @default(0)
  freeAdUsed           Boolean              @default(false)
  stripeCustomerId     String?              @unique
  otpCode              String?              @map("otp_code")
  otpExpires           DateTime?            @map("otp_expires")
  otpPurpose           String?              @map("otp_purpose")
  isVerified           Boolean              @default(false)
  consentGiven         Boolean              @default(false)
  consentDate          DateTime?
  dataRetentionUntil   DateTime?
  lastLoginAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  packageId            String?
  resetPasswordToken   String?              @map("reset_password_token")
  resetPasswordExpires DateTime?            @map("reset_password_expires")
  aiFeatureUsages      AiFeatureUsage[]
  creditTransactions   CreditTransaction[]
  exports              Export[]
  improvementRequests  ImprovementRequest[]
  listings             Listing[]
  payments             Payment[]
  package              Package?             @relation(fields: [packageId], references: [id])

  @@index([email])
}

model Package {
  id             String    @id @default(uuid())
  name           String
  slug           String    @unique
  price          Float
  title          String
  credits        Int
  pricePerCredit Float
  badge          Boolean   @default(false)
  description    String
  features       Json
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  payments       Payment[]
  users          User[]
}

model Listing {
  id                  String               @id @default(uuid())
  userId              String
  location            String
  listingName         String?
  propertyType        PropertyType
  surface             Float?
  rooms               Float?
  floor               String?
  hasElevator         Boolean?
  rent                Float
  charges             Float?
  parkingPrice        Float?
  condition           PropertyCondition
  exposure            Exposure
  equipment           String?
  availableFrom       DateTime?
  petsAllowed         Boolean?
  proximity           String?
  additionalInfo      String?
  title               String?
  description         String?
  highlights          String?
  score               Int?
  status              ListingStatus        @default(DRAFT)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  aiFeatureUsages     AiFeatureUsage[]
  exports             Export[]
  generations         Generation[]
  improvementRequests ImprovementRequest[]
  user                User                 @relation(fields: [userId], references: [id])
  photos              Photo[]

  @@index([userId])
  @@index([createdAt])
}

model Generation {
  id               String           @id @default(uuid())
  listingId        String
  title            String
  hook             String
  description      String
  highlights       Json
  practicalInfo    String?
  score            Int
  suggestions      Json
  version          Int
  isUnlocked       Boolean          @default(false)
  promptTemplateId String?
  generatedText    String?          @db.Text
  updatedAt        DateTime         @updatedAt
  createdAt        DateTime         @default(now())
  aiFeatureUsages  AiFeatureUsage[]
  exports          Export[]
  listing          Listing          @relation(fields: [listingId], references: [id])
  promptTemplate   PromptTemplate?  @relation(fields: [promptTemplateId], references: [id])

  @@index([listingId])
}

model AiFeatureUsage {
  id           String        @id @default(uuid())
  userId       String
  listingId    String
  generationId String
  feature      AiFeatureType
  creditCost   Int
  resultText   String?
  createdAt    DateTime      @default(now())
  generation   Generation    @relation(fields: [generationId], references: [id])
  listing      Listing       @relation(fields: [listingId], references: [id])
  user         User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([listingId])
}

model ImprovementRequest {
  id          String                   @id @default(uuid())
  userId      String
  listingId   String
  paymentId   String?                  @unique
  status      ImprovementRequestStatus @default(PENDING)
  userNote    String?
  adminNote   String?
  resolvedAt  DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  listing     Listing                  @relation(fields: [listingId], references: [id])
  payment     Payment?                 @relation(fields: [paymentId], references: [id])
  user        User                     @relation(fields: [userId], references: [id])
  suggestions ImprovementSuggestion[]

  @@index([userId])
  @@index([listingId])
  @@index([status])
}

model ImprovementSuggestion {
  id                   String             @id @default(uuid())
  improvementRequestId String
  fieldName            String
  currentValue         String?
  suggestedValue       String?
  note                 String?
  isApplied            Boolean            @default(false)
  appliedAt            DateTime?
  createdAt            DateTime           @default(now())
  improvementRequest   ImprovementRequest @relation(fields: [improvementRequestId], references: [id])

  @@index([improvementRequestId])
}

model Photo {
  id        String  @id @default(uuid())
  url       String
  listingId String
  order     Int
  isPrimary Boolean @default(false)
  listing   Listing @relation(fields: [listingId], references: [id])
}

model Payment {
  id                    String              @id @default(uuid())
  userId                String
  amount                Float
  credits               Int                 @default(0)
  type                  PaymentType
  status                PaymentStatus
  stripeSessionId       String
  stripePaymentIntentId String
  stripeCustomerId      String?
  packageId             String?
  createdAt             DateTime            @default(now())
  improvementRequest    ImprovementRequest?
  package               Package?            @relation(fields: [packageId], references: [id])
  user                  User                @relation(fields: [userId], references: [id])

  @@index([userId])
}

model CreditTransaction {
  id        String                @id @default(uuid())
  userId    String
  amount    Int
  type      CreditTransactionType
  reference String?
  createdAt DateTime              @default(now())
  user      User                  @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Export {
  id           String      @id @default(uuid())
  listingId    String
  userId       String
  generationId String?
  type         ExportType
  emailTo      String?
  createdAt    DateTime    @default(now())
  generation   Generation? @relation(fields: [generationId], references: [id])
  listing      Listing     @relation(fields: [listingId], references: [id])
  user         User        @relation(fields: [userId], references: [id])

  @@index([userId, listingId])
}

model PromptTemplate {
  id          String       @id @default(uuid())
  name        String
  content     String
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  generations Generation[]
}

enum UserRole {
  ADMIN
  USER
}

enum ListingStatus {
  DRAFT
  PREVIEW
  PAID
  UNLOCKED
  IMPROVEMENT_REQUESTED
  IMPROVEMENT_IN_REVIEW
  IMPROVEMENT_DONE
}

enum PaymentType {
  PACKAGE
  LISTING_UNLOCK
  AI_FEATURE
  IMPROVEMENT_REQUEST
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PropertyType {
  APARTMENT
  HOUSE
  STUDIO
  COMMERCIAL
  OTHER
}

enum PropertyCondition {
  NEW
  GOOD
  RENOVATED
  TO_RENOVATE
}

enum Exposure {
  NORTH
  SOUTH
  EAST
  WEST
  MIXED
}

enum ExportType {
  PDF
  COPY
  EMAIL
}

enum CreditTransactionType {
  FREE
  PURCHASE
  USAGE
  REFUND
}

enum AiFeatureType {
  WARMER_TONE
  SHORTEN_TEXT
  HIGHLIGHT_LOCATION
  OPTIMIZE_INVESTORS
  OPTIMIZE_AIRBNB
  MAKE_PREMIUM
  REGENERATE
  CUSTOM
}

enum ImprovementRequestStatus {
  PENDING
  IN_REVIEW
  SUGGESTION_SENT
  COMPLETED
  REJECTED
}
